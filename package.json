{
  "name": "base_astro_project",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "predev": "node -e \"const { execSync } = require('node:child_process'); try { execSync('gcloud --version', { stdio: 'ignore' }); execSync('gcloud auth application-default print-access-token', { stdio: 'ignore' }); } catch (err) { console.error('ADC not available. Run: gcloud auth application-default login'); process.exit(1); }\"",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "start": "node ./dist/server/entry.mjs",
    "check": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "e2e": "playwright test",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/node": "^9.5.2",
    "@astrojs/react": "^4.4.2",
    "@tailwindcss/vite": "^4.1.18",
    "@types/canvas-confetti": "^1.9.0",
    "astro": "^5.16.6",
    "canvas-confetti": "^1.9.4",
    "firebase-admin": "^12.6.0",
    "flowbite": "^3.1.1",
    "gsap": "^3.14.2",
    "lucide-static": "^0.562.0",
    "node-ical": "^0.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@typescript-eslint/eslint-plugin": "^8.30.0",
    "@typescript-eslint/parser": "^8.30.0",
    "astro-eslint-parser": "^1.2.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-astro": "^0.33.0",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.0",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "vitest": "^4.0.17"
  }
}
