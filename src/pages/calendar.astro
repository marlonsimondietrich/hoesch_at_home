---
import Layout from "../layouts/main.astro";
import { BigCalendar } from "../features/bookings/ui/BigCalendar";
---

<Layout
  content={{
    title: "Kalender",
    description: "Uebersicht der geblockten Buchungen.",
  }}
>
  <section class="min-h-screen bg-[#fff9ee] py-10">
    <div class="mx-auto w-full max-w-none space-y-10 px-6 lg:px-12">
      <header class="space-y-3">
        <p class="section-eyebrow">Verfuegbarkeit</p>
        <h1 class="section-title text-[2.8rem] leading-[1.05] md:text-[3.4rem]">
          Kalender
        </h1>
        <p class="section-body max-w-2xl">
          Geblockte Daten aus der Datenbank und externen Kalendern sind deaktiviert.
        </p>
      </header>
      <BigCalendar client:load />
    </div>
  </section>
</Layout>
