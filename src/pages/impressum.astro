        <section>
          <h2 class="text-xl font-semibold">Umsatzsteuer-ID</h2>
          <p class="mt-3">Umsatzsteuer-Identifikationsnummer gemäß § 27a UStG: DE259911362</p>
        </section>

        <section>
          <h2 class="text-xl font-semibold">Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV</h2>
          <p class="mt-3">
            Michael Hoesch<br />
            Zellerstrasse 29<br />
            82067 Ebenhausen<br />
            Deutschland
          </p>
        </section>
      </div>
    </section>
  </main>
</Layout>
