      <p class="section-eyebrow">Rechtliches</p>
      <h1 class="section-title mt-4">Impressum</h1>
      <div class="section-body mt-6 max-w-2xl space-y-8">
        <section>
          <h2 class="text-xl font-semibold">Angaben gemäß § 5 DDG</h2>
          <p class="mt-3">
            Hoesch Beteiligungsverwaltung GmbH<br />
            Zellerstrasse 29<br />
            82067 Ebenhausen<br />
            Deutschland
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold">Vertreten durch</h2>
          <p class="mt-3">Geschäftsführer: Michael Hoesch</p>
        </section>

        <section>
          <h2 class="text-xl font-semibold">Kontakt</h2>
