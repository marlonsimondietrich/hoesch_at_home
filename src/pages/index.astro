---
import Layout from '../layouts/main.astro';
import HomePage from '../components/HomePage.astro';
import NavBar from '../components/NavBar.astro';
import { defaultLocale, getStrings, type Locale } from '../i18n';
import { getPathByLocale, getRelativeLocaleUrl } from 'astro:i18n';
import { getHomeSections } from '../components/sections/homeSections';
import { getNavLinks } from '../lib/navigation';

const currentLocale = (Astro.currentLocale ?? defaultLocale) as Locale;
const localePath = getPathByLocale(currentLocale);
const pathWithoutLocale =
  Astro.url.pathname.replace(new RegExp(`^/${localePath}(?=/|$)`), '') || '/';
const pathParam =
  pathWithoutLocale === '/' ? undefined : pathWithoutLocale.replace(/^\/+/, '');
const alternateLocale: Locale = currentLocale === 'de' ? 'en' : 'de';
const alternateLocaleHref = getRelativeLocaleUrl(alternateLocale, pathParam);
const content = getStrings(currentLocale).home;
const homeHref = getRelativeLocaleUrl(currentLocale);
const calendarHref = getRelativeLocaleUrl(currentLocale, 'calendar');
const sections = getHomeSections(content);
const links = getNavLinks(sections, homeHref, calendarHref);
---

<Layout
  content={{
    title: content.metaTitle,
    description: content.metaDescription,
  }}
>
  <section class="bg-gradient-to-br from-orange-50 via-amber-50/70 to-slate-50 text-slate-900 lg:px-12">
    <NavBar
      links={links}
      homeHref={homeHref}
      alternateLocaleHref={alternateLocaleHref}
      languageToggleLabel={content.navLanguageToggleLabel}
      languageToggleAria={content.navLanguageToggleAria}
    />
    <main>
      <HomePage content={content} currentLocale={currentLocale} />
    </main>
  </section>
</Layout>
