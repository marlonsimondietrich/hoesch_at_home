---
import heroBg from '../assets/hero-bg.png';
import heroIllustration from '../assets/hoeschathome-illustration.png';
import type { HomeContent } from '../i18n';

interface Props {
  content: HomeContent;
  currentLocale?: string;
}

const { content } = Astro.props;
const {
  heroEyebrow,
  heroHeadline,
  heroBody,
  heroFeatures,
  heroPrimaryCtaLabel,
  heroPrimaryCtaHref,
  heroSecondaryCtaLabel,
  heroSecondaryCtaHref,
  heroAlt,
} = content;
---

<section
  class="relative overflow-hidden px-4 pb-16 text-slate-900 sm:px-6 sm:pb-24 lg:px-8"
  style={`background-image: url(${heroBg.src}); background-size: 100% auto; background-position: center top; background-repeat: no-repeat; background-color: #f8f5f2; min-height: 70vh;`}
>
  <div class="flex flex-col items-center gap-8 text-center">
    {
      heroEyebrow && (
        <p class="text-sm tracking-[0.2em] text-amber-700/80 uppercase">{heroEyebrow}</p>
      )
    }
    <h1 class="text-4xl leading-tight font-semibold tracking-tight text-balance sm:text-5xl">
      {heroHeadline}
    </h1>
    <div class="max-w-3xl space-y-3 text-lg text-pretty text-slate-700">
      {heroBody.map((line) => <p>{line}</p>)}
    </div>
    <img
      src={heroIllustration.src}
      alt={heroAlt}
      class="relative max-h-[360px] w-full max-w-2xl object-contain"
      loading="eager"
      data-hero-illustration
    />
    <div class="flex max-w-3xl flex-wrap justify-center gap-3 pt-2">
      {
        heroFeatures.map((item) => (
          <span class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white/70 px-4 py-2 text-sm font-semibold text-slate-800 shadow-sm">
            {item}
          </span>
        ))
      }
    </div>
    <div class="flex flex-col justify-center gap-3 sm:flex-row sm:gap-4">
      <a
        href={heroPrimaryCtaHref}
        class="inline-flex items-center justify-center rounded-full bg-[#B85E3C] px-6 py-3 text-base font-semibold text-white shadow-sm transition-colors hover:bg-[#a34f32] focus:outline-none focus-visible:ring focus-visible:ring-[#B85E3C] focus-visible:ring-offset-2"
        data-hero-primary
      >
        {heroPrimaryCtaLabel}
      </a>
      <a
        href={heroSecondaryCtaHref}
        class="inline-flex items-center justify-center rounded-full border border-slate-300 px-6 py-3 text-base font-semibold text-slate-800 transition-colors hover:border-slate-400 hover:text-slate-900 focus:outline-none focus-visible:ring focus-visible:ring-amber-500 focus-visible:ring-offset-2"
        data-hero-secondary
      >
        {heroSecondaryCtaLabel}
      </a>
    </div>
  </div>
