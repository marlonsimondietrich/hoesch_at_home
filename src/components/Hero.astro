---
import heroBg from '../assets/hero-bg.png';
import heroIllustration from '../assets/hoeschathome-illustration.png';
import chickButton from '../assets/decorative-elements/chick-button.png';
import chickButtonHovered from '../assets/decorative-elements/chick-button-hovered.png';
import type { HomeContent, Locale } from '../i18n';
import { getRelativeLocaleUrl } from 'astro:i18n';

interface Props {
  content: HomeContent;
  currentLocale: Locale;
}

const { content, currentLocale } = Astro.props;
const {
  heroEyebrow,
  heroHeadline,
  heroBody,
  heroFeatures,
  heroAlt,
} = content;

const calendarHref = getRelativeLocaleUrl(currentLocale, 'calendar');
---

<section
  id="section-hero"
  class="relative overflow-visible text-slate-900 px-4 sm:px-6 lg:px-8 pt-12 sm:pt-16 lg:pt-20 pb-32 sm:pb-40 lg:pb-48"
  style={`background-image: url(${heroBg.src}); background-size: cover; background-position: center bottom; background-repeat: no-repeat; background-color: #fffcf0; min-height: 70vh;`}
>
  <div class="mx-auto w-full max-w-6xl">
    <div class="flex flex-col items-start text-left gap-5 max-w-3xl">
      {heroEyebrow && (
        <p class="text-sm uppercase tracking-[0.2em] text-amber-700/80">
          {heroEyebrow}
        </p>
      )}
      <h1 class="text-4xl sm:text-5xl font-semibold leading-tight tracking-tight">
        {heroHeadline}
      </h1>
      <div class="space-y-3 text-lg text-slate-700">
        {heroBody.map((line) => (
          <p>{line}</p>
        ))}
      </div>
    </div>
    <div class="mt-12 flex w-full flex-col gap-12 lg:flex-row lg:items-start lg:justify-between">
      <div class="flex flex-col items-start gap-8 max-w-3xl">
        <div class="relative max-h-[360px] w-full max-w-2xl self-start">
          <img
            src={heroIllustration.src}
            alt={heroAlt}
            class="hero-illustration relative h-full w-full object-contain"
            loading="eager"
            data-hero-illustration
          />
        </div>
        <div class="flex flex-wrap justify-start gap-3">
          {heroFeatures.map((item) => (
            <span class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white/70 px-4 py-2 text-sm font-semibold text-slate-800 shadow-sm">
              {item}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
  <a
    href={calendarHref}
    class="absolute right-6 flex flex-col items-center gap-2 text-center sm:right-8 chick-button"
    style="bottom: 30%;"
    aria-label="Jetzt buchen"
  >
    <span class="chick-button-image h-20 w-20 sm:h-24 sm:w-24">
      <img
        src={chickButton.src}
        alt="Jetzt buchen"
        class="chick-button-default h-full w-full"
        loading="eager"
      />
      <img
        src={chickButtonHovered.src}
        alt=""
        class="chick-button-hover h-full w-full"
        loading="eager"
      />
    </span>
    <span class="chick-button-label text-[#FFFCF0]">Jetzt buchen</span>
  </a>
