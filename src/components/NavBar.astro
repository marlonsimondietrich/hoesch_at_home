---
import logo from '../assets/logo.png';

interface Props {
  links: { label: string; href: string }[];
  homeHref: string;
  alternateLocaleHref: string;
  languageToggleLabel: string;
  languageToggleAria: string;
}

const { links, homeHref, alternateLocaleHref, languageToggleLabel, languageToggleAria } =
  Astro.props;
---

<nav class="flex items-center justify-between p-4 bg-transparent shadow-none">
  <a href={homeHref} class="inline-flex items-center gap-2">
    <img src={logo.src} alt="Hoesch@Home logo" class="h-20 w-auto" loading="eager" />
    <span class="sr-only">Hoesch@Home</span>
  </a>
  <div class="flex items-center gap-4">
    <ul class="flex gap-4">
      {links.map((link) => (
        <li><a href={link.href} class="text-slate-600 hover:text-slate-900">{link.label}</a></li>
      ))}
    </ul>
    <a
      href={alternateLocaleHref}
      class="inline-flex items-center justify-center rounded-full border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-800 transition-colors hover:border-slate-300 hover:text-slate-900 focus:outline-none focus-visible:ring focus-visible:ring-amber-500 focus-visible:ring-offset-2"
      aria-label={languageToggleAria}
      data-lang-toggle
    >
      {languageToggleLabel}
    </a>
  </div>
</nav>
