---
import logo from '../assets/logo.svg';
import type { Locale } from '../i18n';

interface Props {
  currentLocale: Locale;
}

const { currentLocale } = Astro.props;

const links =
  currentLocale === 'de'
    ? [
        { label: 'Impressum', href: '/impressum' },
        { label: 'Datenschutzerklärung', href: '/datenschutzerklaerung' },
      ]
    : [
        { label: 'Legal Notice', href: '/en/legal-notice' },
        { label: 'Privacy Policy', href: '/en/privacy-policy' },
      ];

const homeHref = currentLocale === 'de' ? '/' : '/en';
---

<footer class="mt-auto bg-[#556E56] text-[#fffcf0]">
  <div class="container-responsive flex flex-col gap-5 py-8 sm:flex-row sm:items-center sm:justify-between">
    <a href={homeHref} aria-label="Zur Startseite" class="block">
      <span
        role="img"
        aria-label="Hoesch@Home"
        class="block h-40 w-[22rem] bg-[#FBFBF6]"
        style={`mask-image: url(${logo.src}); mask-repeat: no-repeat; mask-size: contain; mask-position: left center; -webkit-mask-image: url(${logo.src}); -webkit-mask-repeat: no-repeat; -webkit-mask-size: contain; -webkit-mask-position: left center;`}
      ></span>
    </a>
    <nav aria-label="Legal" class="flex flex-wrap items-center gap-x-6 gap-y-3 text-sm">
      {links.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors duration-200 hover:text-white focus:outline-none focus-visible:text-white"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</footer>
