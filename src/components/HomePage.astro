---
import Hero from './Hero.astro';
import type { HomeContent, Locale } from '../i18n';
import { getHomeSections } from './sections/homeSections';
import DecorativeBlocks from './sections/DecorativeBlocks.astro';

export interface Props {
  content: HomeContent;
  currentLocale: Locale;
}

const { content, currentLocale } = Astro.props;

const sections = getHomeSections(content);
---
<Hero content={content} currentLocale={currentLocale} />
<DecorativeBlocks content={content} />
{sections.map(({ id, Component }) => (
  <Component id={id} content={content} />
))}
