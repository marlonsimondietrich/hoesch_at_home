---
import NavBar from './NavBar.astro';
import Hero from './Hero.astro';
import BookingWidget from '../features/bookings/ui/BookingWidget';
import type { HomeContent, Locale } from '../i18n';
import { getRelativeLocaleUrl } from 'astro:i18n';
import photo7 from '../assets/photos/7.avif';
import photo10 from '../assets/photos/10.avif';

interface Props {
  content: HomeContent;
  currentLocale: Locale;
  alternateLocaleHref: string;
}

const { content, currentLocale, alternateLocaleHref } = Astro.props;

const homeHref = getRelativeLocaleUrl(currentLocale);

const { navHome, navAbout, navContact } = content;
const links = [
  { label: navHome, href: homeHref },
  { label: navAbout, href: '#' },
  { label: navContact, href: '#' },
];
---

<NavBar
  links={links}
  homeHref={homeHref}
  alternateLocaleHref={alternateLocaleHref}
  languageToggleLabel={content.navLanguageToggleLabel}
  languageToggleAria={content.navLanguageToggleAria}
/>

<main>
  <Hero content={content} currentLocale={currentLocale} />
  <section
    aria-hidden="true"
    class="min-h-[90vh]"
    style={`background-image: linear-gradient(rgba(173, 84, 50, 0.2), rgba(173, 84, 50, 0.2)), url(${photo7.src}); background-size: cover; background-position: center bottom; background-repeat: no-repeat;`}
  ></section>
  <section aria-hidden="true" class="min-h-[40vh]" style="background-color: #c77a5b;"></section>
  <section
    aria-hidden="true"
    class="min-h-[60vh]"
    style={`background-image: linear-gradient(rgba(173, 84, 50, 0.2), rgba(173, 84, 50, 0.2)), url(${photo10.src}); background-size: cover; background-position: center bottom; background-repeat: no-repeat;`}
  ></section>
  <section aria-hidden="true" class="min-h-[40vh]" style="background-color: #ad5432;"></section>
  <BookingWidget client:load content={content} />
</main>
